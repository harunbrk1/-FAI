<script>
const GROQ_MODEL = "llama-3.3-70b-versatile";
const GROQ_URL   = "https://api.groq.com/openai/v1/chat/completions";

const MODULES = [
  { name:"Semptom Analizi", emoji:"🩺", ic:"ig", desc:"Belirtilerini yaz, AI halk diliyle açıklasın", ph:"Örn: Başım ağrıyor ve ateşim var...", quick:["Baş ağrısı var","Mide bulantısı","Yorgunluk ve halsizlik","Öksürük ve boğaz ağrısı"], welcome:"Belirtilerini yaz, sana yardımcı olayım. Karmaşık tıbbi terimler yok — sade ve anlaşılır şekilde açıklıyorum.", system:`Sen ŞİFAİ'nin Semptom Analizi asistanısın. Türk kullanıcılara sağlık konularında Türkçe yardım et. Halk diliyle konuş, kesin teşhis koyma. Acil durumlarda 112'yi söyle. Emoji kullan. Kısa ve öz yanıt ver.` },
  { name:"İlaç Bilgi Sistemi", emoji:"💊", ic:"ib", desc:"Türkiye ilaçları, SGK kapsamı ve muadil önerileri", ph:"Örn: Majezik ne işe yarar?", quick:["Majezik ne işe yarar?","Augmentin yan etkileri","SGK karşılıyor mu?","Muadil ilaç var mı?"], welcome:"İlaç adını yaz, ne işe yaradığını, yan etkilerini ve SGK kapsamını öğren.", system:`Sen ŞİFAİ'nin İlaç Bilgi asistanısın. Türkiye ilaçları hakkında bilgi ver. Yan etkiler, SGK kapsamı, muadil ilaçlar. Reçete gerekliliğini belirt. Emoji kullan.` },
  { name:"Sağlık Koçu", emoji:"🧘", ic:"it", desc:"Kişisel sağlık takibi ve yaşam tarzı önerileri", ph:"Örn: 30 yaşındayım, 80 kg. Daha sağlıklı yaşamak istiyorum.", quick:["Günlük su ne kadar?","Egzersiz önerisi","Bağışıklık güçlendirme","Kilo verme"], welcome:"Yaşın, kilonu ve hedeflerini paylaş — sana özel sağlık önerileri hazırlayayım.", system:`Sen ŞİFAİ'nin Sağlık Koçusun. Türkiye yaşam koşullarına uygun, kişiselleştirilmiş sağlık önerileri ver. Motive edici ve pozitif ol.` },
  { name:"Uyku & Stres", emoji:"😴", ic:"ibj", desc:"Uyku kalitesi ve stres yönetimi analizi", ph:"Örn: Son hafta çok stresli hissediyorum.", quick:["Uyuyamıyorum","Stres azaltma","Uyku düzeni","Kaygı ile başa çıkma"], welcome:"Uyku düzenin ve stres seviyeni anlat, birlikte çözüm bulalım.", system:`Sen ŞİFAİ'nin Uyku ve Stres asistanısın. Empatiyle yanıt ver. Pratik teknikler öner. Ciddi durumlarda uzmana yönlendir.` },
  { name:"Hastane Yönlendirme", emoji:"🏥", ic:"ib", desc:"Hangi uzmana gideceğini ve SGK kapsamını öğren", ph:"Örn: Dizim çok ağrıyor, hangi doktora gideyim?", quick:["Hangi doktora gideyim?","SGK kapsamı","MHRS randevu","Acil mi?"], welcome:"Şikayetini söyle, hangi uzmana gideceğini ve nasıl randevu alacağını anlatalım.", system:`Sen ŞİFAİ'nin Hastane Yönlendirme asistanısın. Türkiye sağlık sistemi: SGK, MHRS, aile hekimi, e-Nabız hakkında bilgi ver. Acilde 112 söyle.` },
  { name:"Diyetisyen AI", emoji:"🥗", ic:"ig", desc:"Türk mutfağına özel kişisel beslenme planları", ph:"Örn: Kilo vermek istiyorum, Türk yemeklerini seviyorum.", quick:["Haftalık plan yap","Türk mutfağında diyet","Ramazan'da beslenme","Sağlıklı kahvaltı"], welcome:"Beslenme alışkanlıklarını paylaş, Türk mutfağına özel beslenme planı hazırlayayım. 🥗", system:`Sen ŞİFAİ'nin Diyetisyen asistanısın. Türk yemeklerini ön plana çıkar. Ekonomik ve pratik öneriler ver. Kronik hastalıklarda uzmana yönlendir.` }
];

let apiKey = "";
let currentMod = 0;
let convos = MODULES.map(() => []);
let loading = false;

// ── OVERLAY CONTROLS ──────────────────────────────────
function openChat(modIdx = 0) {
  if (!apiKey) {
    pendingMod = modIdx;
    openSetup();
    return;
  }
  switchMod(modIdx);
  document.getElementById("chatOverlay").classList.add("active");
  document.body.style.overflow = "hidden";
}

function closeChat() {
  document.getElementById("chatOverlay").classList.remove("active");
  document.body.style.overflow = "";
}

let pendingMod = 0;
function openSetup() { document.getElementById("setupOverlay").classList.add("active"); }
function closeSetup() { document.getElementById("setupOverlay").classList.remove("active"); }

function connectAPI() {
  const k = document.getElementById("apiKeyInput").value.trim();
  if (!k || !k.startsWith("gsk_")) { alert("Geçerli bir Groq key gir (gsk_ ile başlamalı)"); return; }
  apiKey = k;
  localStorage.setItem("shifai_key", k);
  closeSetup();
  openChat(pendingMod);
}

function scrollToTop() { window.scrollTo({ top: 0, behavior: "smooth" }); }

// Auto-login
window.onload = () => {
  const saved = localStorage.getItem("shifai_key");
  if (saved) apiKey = saved;
  buildTabs();
};

// ── TABS ──────────────────────────────────────────────
function buildTabs() {
  document.getElementById("modTabs").innerHTML = MODULES.map((m,i) =>
    `<button class="mtab${i===0?' active':''}" onclick="switchMod(${i})">${m.emoji} ${m.name}</button>`
  ).join("");
}

function switchMod(i) {
  currentMod = i;
  document.querySelectorAll(".mtab").forEach((t,j) => t.classList.toggle("active", i===j));
  const m = MODULES[i];
  document.getElementById("modIcon").textContent = m.emoji;
  document.getElementById("modIcon").className = "mod-icon " + m.ic;
  document.getElementById("modName").textContent = m.name;
  document.getElementById("modDesc").textContent = m.desc;
  document.getElementById("inputBox").placeholder = m.ph;
  document.getElementById("quickPrompts").innerHTML =
    m.quick.map(q => `<button class="qbtn" onclick="useQuick('${q}')">${q}</button>`).join("");
  renderMsgs();
}

// ── MESSAGES ──────────────────────────────────────────
function renderMsgs() {
  const msgs = convos[currentMod];
  const el = document.getElementById("messages");
  if (msgs.length === 0) {
    const m = MODULES[currentMod];
    el.innerHTML = `<div class="welcome-box"><div class="welcome-emoji">${m.emoji}</div><h3 class="welcome-title">${m.name}</h3><p class="welcome-desc">${m.welcome}</p></div>`;
    return;
  }
  el.innerHTML = msgs.map(msg => `
    <div class="msg-wrap ${msg.role}">
      <div class="msg-bubble ${msg.role}">${fmt(msg.content)}</div>
      <div class="msg-time">${msg.time}</div>
    </div>`).join("");
  setTimeout(() => { el.scrollTop = el.scrollHeight; }, 50);
}

function fmt(t) {
  return t.replace(/\*\*(.*?)\*\*/g,"<strong>$1</strong>").replace(/\*(.*?)\*/g,"<em>$1</em>").replace(/\n/g,"<br>");
}

function useQuick(q) { document.getElementById("inputBox").value = q; sendMessage(); }
function handleKey(e) { if (e.key==="Enter" && !e.shiftKey) { e.preventDefault(); sendMessage(); } }
function autoResize(el) { el.style.height="auto"; el.style.height=Math.min(el.scrollHeight,110)+"px"; }

// ── SEND ──────────────────────────────────────────────
async function sendMessage() {
  if (loading) return;
  const box = document.getElementById("inputBox");
  const text = box.value.trim();
  if (!text) return;

  box.value=""; box.style.height="auto";
  loading=true; document.getElementById("sendBtn").disabled=true;

  const now = new Date().toLocaleTimeString("tr-TR",{hour:"2-digit",minute:"2-digit"});
  convos[currentMod].push({ role:"user", content:text, time:now });
  renderMsgs();

  const msgEl = document.getElementById("messages");
  const typing = document.createElement("div");
  typing.className="typing-wrap"; typing.id="typing";
  typing.innerHTML=`<div class="typing-bubble"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>`;
  msgEl.appendChild(typing);
  msgEl.scrollTop = msgEl.scrollHeight;

  try {
    const m = MODULES[currentMod];
    const history = convos[currentMod].map(msg=>({ role: msg.role==="ai"?"assistant":"user", content: msg.content }));
    const res = await fetch(GROQ_URL, {
      method:"POST",
      headers:{ "Content-Type":"application/json", "Authorization":`Bearer ${apiKey}` },
      body: JSON.stringify({ model:GROQ_MODEL, messages:[{role:"system",content:m.system},...history], max_tokens:1024, temperature:0.7 })
    });
    if (!res.ok) { const e=await res.json(); throw new Error(e.error?.message||`HTTP ${res.status}`); }
    const data = await res.json();
    const reply = data.choices[0].message.content;
    document.getElementById("typing")?.remove();
    convos[currentMod].push({ role:"ai", content:reply, time:now });
    renderMsgs();
  } catch(err) {
    document.getElementById("typing")?.remove();
    const errEl = document.createElement("div");
    errEl.className="msg-wrap ai";
    errEl.innerHTML=`<div class="error-bubble">⚠️ Hata: ${err.message}<br><small>API key'ini kontrol et veya yenile.</small></div>`;
    document.getElementById("messages").appendChild(errEl);
  }

  loading=false; document.getElementById("sendBtn").disabled=false;
  document.getElementById("inputBox").focus();
}
</script>

